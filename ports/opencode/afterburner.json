{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "dark_bg":              "#0D0D0D",
    "dark_surface":         "#1A1A1A",
    "dark_surface2":        "#252525",
    "dark_border":          "#2A2A2A",
    "dark_border_active":   "#CC3F00",
    "dark_border_subtle":   "#1E1E1E",
    "dark_fg":              "#E0E0E0",
    "dark_fg_muted":        "#666666",
    "dark_fg_dim":          "#444444",
    "dark_diff_add_bg":     "#0D1F12",
    "dark_diff_rem_bg":     "#1A0A08",
    "dark_diff_ctx_bg":     "#131313",

    "light_bg":             "#F5F0EB",
    "light_surface":        "#EDE5DC",
    "light_surface2":       "#E4DAD0",
    "light_border":         "#DDD5CC",
    "light_border_active":  "#A33200",
    "light_border_subtle":  "#EAE2D8",
    "light_fg":             "#2A2218",
    "light_fg_muted":       "#9A9088",
    "light_fg_dim":         "#C0B8B0",
    "light_diff_add_bg":    "#E8F2EC",
    "light_diff_rem_bg":    "#F5E5E4",
    "light_diff_ctx_bg":    "#EDE5DC",

    "orange_dark":          "#FF4F00",
    "orange_mid_dark":      "#FF7A33",
    "orange_pale_dark":     "#FFB380",
    "orange_cursor_dark":   "#CC3F00",
    "orange_deep_dark":     "#7A2600",

    "orange_light":         "#C94000",
    "orange_mid_light":     "#D45A00",
    "orange_pale_light":    "#B87040",
    "orange_cursor_light":  "#A33200",
    "orange_deep_light":    "#7A2600",

    "warm_gray":            "#A89888",
    "red":                  "#BA160C",
    "red_bright_dark":      "#E8352A",
    "red_bright_light":     "#D4352A",
    "green_dark":           "#5FBF7E",
    "green_light":          "#2E7D4F",
    "amber_dark":           "#E09B30",
    "amber_light":          "#9A6A10",
    "teal_dark":            "#4DBFA8",
    "teal_light":           "#2D8C7A",
    "blue_dark":            "#4A8AB5",
    "blue_light":           "#2A6A9A",
    "purple_dark":          "#A07DE0",
    "purple_light":         "#7058C0"
  },
  "theme": {
    "primary":           { "dark": "orange_dark",        "light": "orange_light" },
    "secondary":         { "dark": "orange_mid_dark",    "light": "orange_mid_light" },
    "accent":            { "dark": "orange_pale_dark",   "light": "orange_pale_light" },
    "error":             { "dark": "red",                "light": "red" },
    "warning":           { "dark": "amber_dark",         "light": "amber_light" },
    "success":           { "dark": "green_dark",         "light": "green_light" },
    "info":              { "dark": "blue_dark",          "light": "blue_light" },

    "text":              { "dark": "dark_fg",            "light": "light_fg" },
    "textMuted":         { "dark": "dark_fg_muted",      "light": "light_fg_muted" },
    "background":        { "dark": "dark_bg",            "light": "light_bg" },
    "backgroundPanel":   { "dark": "dark_surface",       "light": "light_surface" },
    "backgroundElement": { "dark": "dark_surface2",      "light": "light_surface2" },
    "border":            { "dark": "dark_border",        "light": "light_border" },
    "borderActive":      { "dark": "dark_border_active", "light": "light_border_active" },
    "borderSubtle":      { "dark": "dark_border_subtle", "light": "light_border_subtle" },

    "diffAdded":               { "dark": "green_dark",        "light": "green_light" },
    "diffRemoved":             { "dark": "red",               "light": "red" },
    "diffContext":             { "dark": "dark_fg_dim",       "light": "light_fg_muted" },
    "diffHunkHeader":          { "dark": "orange_cursor_dark","light": "orange_cursor_light" },
    "diffHighlightAdded":      { "dark": "green_dark",        "light": "green_light" },
    "diffHighlightRemoved":    { "dark": "red_bright_dark",   "light": "red_bright_light" },
    "diffAddedBg":             { "dark": "dark_diff_add_bg",  "light": "light_diff_add_bg" },
    "diffRemovedBg":           { "dark": "dark_diff_rem_bg",  "light": "light_diff_rem_bg" },
    "diffContextBg":           { "dark": "dark_diff_ctx_bg",  "light": "light_diff_ctx_bg" },
    "diffLineNumber":          { "dark": "dark_fg_dim",       "light": "light_fg_dim" },
    "diffAddedLineNumberBg":   { "dark": "dark_diff_add_bg",  "light": "light_diff_add_bg" },
    "diffRemovedLineNumberBg": { "dark": "dark_diff_rem_bg",  "light": "light_diff_rem_bg" },

    "markdownText":            { "dark": "dark_fg",           "light": "light_fg" },
    "markdownHeading":         { "dark": "orange_dark",       "light": "orange_light" },
    "markdownLink":            { "dark": "blue_dark",         "light": "blue_light" },
    "markdownLinkText":        { "dark": "teal_dark",         "light": "teal_light" },
    "markdownCode":            { "dark": "orange_pale_dark",  "light": "orange_pale_light" },
    "markdownBlockQuote":      { "dark": "orange_deep_dark",  "light": "light_fg_muted" },
    "markdownEmph":            { "dark": "orange_mid_dark",   "light": "orange_mid_light" },
    "markdownStrong":          { "dark": "orange_dark",       "light": "orange_light" },
    "markdownHorizontalRule":  { "dark": "dark_fg_dim",       "light": "light_fg_dim" },
    "markdownListItem":        { "dark": "orange_mid_dark",   "light": "orange_mid_light" },
    "markdownListEnumeration": { "dark": "orange_cursor_dark","light": "orange_cursor_light" },
    "markdownImage":           { "dark": "blue_dark",         "light": "blue_light" },
    "markdownImageText":       { "dark": "teal_dark",         "light": "teal_light" },
    "markdownCodeBlock":       { "dark": "dark_fg",           "light": "light_fg" },

    "syntaxComment":     { "dark": "dark_fg_dim",       "light": "light_fg_dim" },
    "syntaxKeyword":     { "dark": "orange_dark",       "light": "orange_light" },
    "syntaxFunction":    { "dark": "amber_dark",        "light": "amber_light" },
    "syntaxVariable":    { "dark": "dark_fg",           "light": "light_fg" },
    "syntaxString":      { "dark": "orange_mid_dark",   "light": "orange_mid_light" },
    "syntaxNumber":      { "dark": "teal_dark",         "light": "teal_light" },
    "syntaxType":        { "dark": "warm_gray",         "light": "warm_gray" },
    "syntaxOperator":    { "dark": "orange_mid_dark",   "light": "orange_mid_light" },
    "syntaxPunctuation": { "dark": "dark_fg_muted",     "light": "light_fg_muted" }
  }
}
